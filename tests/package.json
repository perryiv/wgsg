{
  "name": "wgsg-tests",
  "description": "WebGPU Scene Graph Tests",
  "author": "Perry L Miller IV",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "tsc --build",
    "clear": "clear",
    "dev": "vite",
    "lint": "eslint --ext .ts ./src",
    "test": "mocha ./src/main.ts",
    "watch": "yarn run watch-lint",
    "watch-lint": "chokidar \"src/**/*.ts\" --initial --silent --command \"yarn run clear && yarn run compile && yarn run lint && echo watching ...\"",
    "watch-test": "chokidar \"src/**/*.ts\" --initial --silent --command \"yarn run test && echo watching ...\""
  },
  "mocha": {
    "node-option": [ "import=tsx" ]
  },
  "dependencies": {
    "gl-matrix": "^3.4.3"
  },
  "devDependencies": {
    "@types/chai": "^5.2.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.0",
    "@webgpu/types": "^0.1.60",
    "chai": "^4.2.0",
    "chokidar-cli": "^3.0.0",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "mocha": "^11.1.0",
    "tsx": "^4.22.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.2.5"
  }
}
